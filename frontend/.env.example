# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_NAME="Ren YT-DLP"
VITE_APP_VERSION="1.0.0"
VITE_ENVIRONMENT="development"

# Feature Flags
VITE_ENABLE_BROWSER_COOKIES=true
VITE_ENABLE_HISTORY=true
VITE_ENABLE_QUEUE_VISUALIZATION=true
VITE_ENABLE_ADVANCED_OPTIONS=true

# UI Configuration
VITE_DEFAULT_THEME="system"
VITE_MAX_CONCURRENT_DOWNLOADS=5
VITE_DEFAULT_QUALITY="best"
VITE_DEFAULT_FORMAT="mp4"

# Debug & Logging
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL="info"
